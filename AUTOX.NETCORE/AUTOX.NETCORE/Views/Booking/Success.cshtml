@using AUTOX.DOMAIN

@model StatusPageViewModel

@{
    ViewData["Title"] = "Success";
    ViewData["MetaKeywords"] = "AUTOX booking, car wash booking, detailing booking, cut and polish, vehicle care Sri Lanka";
    ViewData["MetaDescription"] = "Book your AUTOX premium automotive care service online. Reserve detailing, cut and polish, washing and more.";
}

<section class="py-5" style="min-height:80vh; display:flex; align-items:center; background:
    radial-gradient(circle at top right, rgba(226,180,0,0.10), transparent 20%),
    radial-gradient(circle at bottom left, rgba(66,111,154,0.12), transparent 25%),
    linear-gradient(135deg, #050b14 0%, #08111d 35%, #0b1422 100%);">

    <div class="container">
        <div class="mx-auto" style="max-width:720px;">
            <div class="text-center p-5"
                 style="background:linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.03));
                        border:1px solid rgba(255,255,255,0.08);
                        border-radius:28px;
                        box-shadow:0 20px 70px rgba(0,0,0,.35);
                        color:#fff;">

                <div class="mx-auto mb-4"
                     style="width:84px;height:84px;border-radius:22px;display:grid;place-items:center;
                            background:linear-gradient(135deg, rgba(226,180,0,0.18), rgba(255,255,255,0.04));
                            border:1px solid rgba(255,255,255,0.09);">
                    <svg width="42" height="42" viewBox="0 0 24 24" fill="none"
                         stroke="#e2b400" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 6L9 17l-5-5"></path>
                    </svg>
                </div>

                <h1 style="font-size:clamp(2rem,4vw,3.2rem); font-weight:900; margin-bottom:1rem;">
                    @(Model?.Title ?? "Success")
                </h1>

                <p style="color:#b9c4d4; font-size:1.08rem; line-height:1.8; margin-bottom:2rem;">
                    @(Model?.Message ?? "Your request has been completed successfully.")
                </p>

                @if (!string.IsNullOrWhiteSpace(Model?.RedirectUrl))
                {
                    <a href="@Model.RedirectUrl"
                       style="display:inline-block; padding:14px 26px; border-radius:999px;
                                  background:linear-gradient(135deg, #e2b400, #ffd84d);
                                  color:#121212; font-weight:800; text-decoration:none;
                                  box-shadow:0 10px 24px rgba(226,180,0,0.25);">
                        @(string.IsNullOrWhiteSpace(Model?.ButtonText) ? "Continue" : Model.ButtonText)
                    </a>
                }
            </div>
        </div>
    </div>
</section>