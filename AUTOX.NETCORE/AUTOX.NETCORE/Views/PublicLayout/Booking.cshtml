@{
    Layout = null;
}

<section class="section-padding pt-4" id="booking">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6 reveal">
                <h2 class="section-title">Book your AUTOX service with ease</h2>
                <p class="section-subtitle">
                    Reserve your appointment for cut and polish, head light polish, glass polish, or glass water spot removal. AUTOX is focused on giving your vehicle a cleaner, sharper, and premium finished look with specialist care and attention.
                </p>
            </div>
            <div class="col-lg-6 reveal">
                <div class="booking-placeholder">
                    <h4>Schedule your visit</h4>
                    <p>
                        Choose your required service, preferred date, and contact details to confirm your booking with AUTOX. Our team will get in touch and make sure your vehicle receives the right treatment for the best possible finish.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>