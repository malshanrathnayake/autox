@{
    Layout = null;
}

<section class="section-padding pt-0" id="contact">
    <div class="container">
        <div class="mb-5 reveal">
            <h2 class="section-title">Contact AUTOX</h2>
            <p class="section-subtitle">
                Get in touch to book your vehicle for cut and polish, head light polish, glass polish, or glass water spot removal.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-4 reveal">
                <div class="contact-card glass-card">
                    <div class="icon-wrap">
                        <svg viewBox="0 0 24 24">
                            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.33 1.78.63 2.63a2 2 0 0 1-.45 2.11L8 9.73a16 16 0 0 0 6.27 6.27l1.27-1.29a2 2 0 0 1 2.11-.45c.85.3 1.73.51 2.63.63A2 2 0 0 1 22 16.92Z"></path>
                        </svg>
                    </div>
                    <h4>Call Us</h4>
                    <p>+94 074 388 4930<br>Contact us directly for bookings and service inquiries.</p>
                </div>
            </div>

            <div class="col-md-4 reveal">
                <div class="contact-card glass-card">
                    <div class="icon-wrap">
                        <svg viewBox="0 0 24 24">
                            <path d="M21 10c0 7-9 11-9 11S3 17 3 10a9 9 0 1 1 18 0Z"></path>
                            <path d="M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"></path>
                        </svg>
                    </div>
                    <h4>Visit AUTOX</h4>
                    @* <p>Your branch address here<br>Sri Lanka</p> *@
                </div>
            </div>

            <div class="col-md-4 reveal">
                <div class="contact-card glass-card">
                    <div class="icon-wrap">
                        <svg viewBox="0 0 24 24">
                            <path d="M8 2v4"></path>
                            <path d="M16 2v4"></path>
                            <path d="M3 10h18"></path>
                            <path d="M5 5h14a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z"></path>
                        </svg>
                    </div>
                    <h4>Working Hours</h4>
                    <p>Every week: 9:00 AM - 6:00 PM<br>Open daily for bookings and inquiries.</p>
                </div>
            </div>
        </div>
    </div>
</section>