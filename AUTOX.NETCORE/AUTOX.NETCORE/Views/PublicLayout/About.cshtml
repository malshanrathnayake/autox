@{
    Layout = null;
}

<section class="section-padding pt-0" id="about">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6 reveal">
                <div class="split-image">
                    <img src="https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=1200&q=80" alt="AUTOX premium vehicle care">
                    <div class="split-badge">
                        <strong>AUTOX Signature Care</strong>
                        <span>Precision polishing, clarity restoration, and premium finish enhancement</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 reveal">
                <h2 class="section-title">Specialist polishing and restoration services that bring your vehicle back to life</h2>
                <p class="section-subtitle mb-4">
                    At AUTOX, every service is focused on restoring shine, improving clarity, and enhancing the overall appearance of your vehicle. From paint refinement to glass treatment, our detailing process is designed to deliver a cleaner, sharper, and more premium finish.
                </p>

                <div class="row g-4">
                    <div class="col-sm-6">
                        <div class="feature-card glass-card">
                            <div class="icon-wrap">
                                <svg viewBox="0 0 24 24">
                                    <path d="M4 14c2.5-4 5.5-6 8-6s5.5 2 8 6"></path>
                                    <path d="M6 16h12"></path>
                                    <path d="M8 19h8"></path>
                                </svg>
                            </div>
                            <h4>Cut &amp; Polish</h4>
                            <p>Removes dullness, light swirl marks, and surface imperfections while restoring depth, gloss, and a refined paint finish.</p>
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <div class="feature-card glass-card">
                            <div class="icon-wrap">
                                <svg viewBox="0 0 24 24">
                                    <path d="M3 12h4"></path>
                                    <path d="M17 12h4"></path>
                                    <path d="M12 3v4"></path>
                                    <path d="M12 17v4"></path>
                                    <path d="M7 7l2 2"></path>
                                    <path d="M15 15l2 2"></path>
                                    <path d="M17 7l-2 2"></path>
                                    <path d="M9 15l-2 2"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                            </div>
                            <h4>Head Light Polish</h4>
                            <p>Improves faded and cloudy headlights by restoring lens clarity for a cleaner look and better light output.</p>
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <div class="feature-card glass-card">
                            <div class="icon-wrap">
                                <svg viewBox="0 0 24 24">
                                    <path d="M5 5h14"></path>
                                    <path d="M4 8h16"></path>
                                    <path d="M6 19h12"></path>
                                    <path d="M7 8l1 11"></path>
                                    <path d="M17 8l-1 11"></path>
                                </svg>
                            </div>
                            <h4>Glass Polish</h4>
                            <p>Refines automotive glass surfaces to reduce minor marks and improve transparency, smoothness, and visual clarity.</p>
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <div class="feature-card glass-card">
                            <div class="icon-wrap">
                                <svg viewBox="0 0 24 24">
                                    <path d="M12 3c2.5 3.2 5 6.1 5 9a5 5 0 1 1-10 0c0-2.9 2.5-5.8 5-9Z"></path>
                                    <path d="M16.5 16.5 21 21"></path>
                                </svg>
                            </div>
                            <h4>Water Spot Removal</h4>
                            <p>Targets stubborn glass water marks and mineral stains to restore a spotless, crystal-clear finish on windows and windshields.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>