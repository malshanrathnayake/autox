@{
    Layout = null;
}

<section class="section-padding" id="services">
    <div class="container">
        <div class="mb-5 reveal">
            <h2 class="section-title">Signature services built around finish, protection, and presence</h2>
            <p class="section-subtitle">
                AUTOX is positioned as a premium vehicle care brand. The layout below is intentionally modular so you can easily replace content or connect sections to your .NET backend later.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-xl-3 reveal">
                <div class="service-card glass-card">
                    <div class="icon-wrap">
                        <svg viewBox="0 0 24 24">
                            <path d="M3 12h18"></path>
                            <path d="M5 12l2-5h10l2 5"></path>
                            <path d="M6 15h.01"></path>
                            <path d="M18 15h.01"></path>
                            <path d="M7 12v5"></path>
                            <path d="M17 12v5"></path>
                        </svg>
                    </div>
                    <h4>Exterior Detailing</h4>
                    <p>Deep wash, decontamination, gloss enhancement, trim revival, and presentation-level finishing for every vehicle class.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 reveal">
                <div class="service-card glass-card">
                    <div class="icon-wrap">
                        <svg viewBox="0 0 24 24">
                            <path d="M4 19h16"></path>
                            <path d="M6 19V9l6-4 6 4v10"></path>
                            <path d="M9 13h6"></path>
                        </svg>
                    </div>
                    <h4>Interior Renewal</h4>
                    <p>Precision cleaning for leather, dashboard surfaces, seats, carpets, and cabin touchpoints with premium-safe methods.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 reveal">
                <div class="service-card glass-card">
                    <div class="icon-wrap">
                        <svg viewBox="0 0 24 24">
                            <path d="M4 20l5-5"></path>
                            <path d="M14 10l6-6"></path>
                            <path d="M8 16l6-6"></path>
                            <path d="M15 3h6v6"></path>
                        </svg>
                    </div>
                    <h4>Paint Correction</h4>
                    <p>Multi-stage correction to reduce swirl marks, haze, and light imperfections while restoring depth and reflection.</p>
                </div>
            </div>

            <div class="col-md-6 col-xl-3 reveal">
                <div class="service-card glass-card">
                    <div class="icon-wrap">
                        <svg viewBox="0 0 24 24">
                            <path d="M12 3l7 4v5c0 4.5-2.8 7.7-7 9-4.2-1.3-7-4.5-7-9V7l7-4Z"></path>
                            <path d="M9.5 12.5l1.7 1.7 3.8-4"></path>
                        </svg>
                    </div>
                    <h4>Protection Packages</h4>
                    <p>Sealants, ceramic-ready prep, surface defense, and finish preservation designed for daily-use and premium vehicles.</p>
                </div>
            </div>
        </div>
    </div>
</section>