@{
    Layout = null;
}

<section class="section-padding" id="fleet">
    <div class="container">
        <div class="mb-5 reveal">
            <h2 class="section-title">Specialized services that define the AUTOX finish</h2>
            <p class="section-subtitle">
                From paint enhancement to glass restoration, AUTOX delivers focused detailing services designed to improve shine, clarity, and overall vehicle appearance with a premium standard.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-lg-3 col-md-6 reveal">
                <div class="showcase-card">
                    <img src="https://images.unsplash.com/photo-1607860108855-64acf2078ed9?auto=format&fit=crop&w=900&q=80" alt="Cut and polish service">
                    <span class="showcase-tag">Paint Enhancement</span>
                    <h5 class="mt-3">Cut &amp; Polish</h5>
                    <p>Restore paint depth, remove dullness, and improve gloss with a polishing process that gives your vehicle a cleaner, sharper finish.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 reveal">
                <div class="showcase-card">
                    <img src="https://images.unsplash.com/photo-1489824904134-891ab64532f1?auto=format&fit=crop&w=900&q=80" alt="Head light polish service">
                    <span class="showcase-tag">Clarity Restore</span>
                    <h5 class="mt-3">Head Light Polish</h5>
                    <p>Bring back clarity to faded and oxidized headlights for a fresher appearance and improved lighting performance.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 reveal">
                <div class="showcase-card">
                    <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?auto=format&fit=crop&w=900&q=80" alt="Glass polish service">
                    <span class="showcase-tag">Glass Refinement</span>
                    <h5 class="mt-3">Glass Polish</h5>
                    <p>Enhance visibility and finish by refining glass surfaces to reduce light marks and improve smoothness and transparency.</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 reveal">
                <div class="showcase-card">
                    <img src="https://images.unsplash.com/photo-1517524206127-48bbd363f3d7?auto=format&fit=crop&w=900&q=80" alt="Glass water spot removal service">
                    <span class="showcase-tag">Spot Removal</span>
                    <h5 class="mt-3">Glass Water Spot Removing</h5>
                    <p>Remove stubborn mineral stains and water marks from glass surfaces to achieve a cleaner, clearer, and more polished look.</p>
                </div>
            </div>
        </div>
    </div>
</section>